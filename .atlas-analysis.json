  "keyFeatures": [
    "Activity heatmap with GitHub-style contribution grid",
    "Session explorer with expandable message threads",
    "Model usage breakdown with cost tracking",
    "Daily token consumption visualization",
    "Tool usage analytics (Read, Edit, Bash, etc.)",
    "Searchable prompt history with copy functionality",
    "Multi-profile support for data comparison",
    "Project-level filtering across all views",
    "100% client-side processing for privacy"
  ],
  "publicApiSurface": [
    "loadAllData() - Load all Claude Code data from ~/.claude/",
    "loadStatsCache() - Load aggregated statistics",
    "loadSessionMetas() - Load session metadata files",
    "loadHistory() - Load prompt history",
    "loadProjectMemories() - Load project memory files",
    "Dashboard component - Main analytics dashboard",
    "StatsOverview component - Summary statistics cards",
    "ActivityHeatmap component - Daily activity visualization",
    "SessionTable component - Session browser with message viewer",
    "ModelBreakdown component - Model usage and cost analysis",
    "ToolUsageChart component - Tool call frequency charts",
    "PromptHistory component - Searchable prompt log",
    "export.mjs script - CLI data export utility"
  ]
}
